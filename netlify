// File: netlify/functions/get-youcam-key.js
exports.handler = async function(event, context) {
    return {
        statusCode: 200,
        body: JSON.stringify({
            // Ini akan menarik YOUTHKAM_API_KEY dari dashboard Environment Netlify
            apiKey: process.env.YOUTHKAM_API_KEY 
        })
    };
};
